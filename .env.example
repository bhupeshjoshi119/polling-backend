# Polling Backend — Environment Variables
# Copy this file to .env and fill in the values

# Server port
PORT=9000

# MongoDB connection string
# Local: mongodb://localhost:27017/pollsdb
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/pollsdb
MONGO_URI=mongodb://localhost:27017/pollsdb

# JWT secret — must match the auth-service JWT_SECRET
JWT_SECRET=myjwtsecret

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173
